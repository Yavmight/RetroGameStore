@model List<RetroGameStore.Models.CartItem>
@{
    ViewData["Title"] = "Shopping Cart";
    var total = Model.Sum(c => c.Price * c.Quantity);
}

<div class="d-flex justify-content-between align-items-center mb-2">
    <div>
        <div class="page-title"><i class="bi bi-cart3"></i> Shopping Cart</div>
        <div class="page-subtitle">@Model.Count item(s) in your cart</div>
    </div>
    <a asp-controller="Orders" asp-action="Browse" class="btn btn-outline-primary">
        <i class="bi bi-arrow-left"></i> Continue Shopping
    </a>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-cart-x" style="font-size: 3rem; color: #555;"></i>
            <p class="text-muted mt-3 mb-4">Your cart is empty</p>
            <a asp-controller="Orders" asp-action="Browse" class="btn btn-primary">
                <i class="bi bi-shop"></i> Browse Games
            </a>
        </div>
    </div>
}
else
{
    <div class="cart-container">
        <div class="cart-items">
            @foreach (var item in Model)
            {
                <div class="cart-item">
                    <div class="cart-item-image">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" alt="@item.Title" />
                        }
                        else
                        {
                            <div class="cart-item-placeholder">
                                <i class="bi bi-joystick"></i>
                            </div>
                        }
                    </div>
                    <div class="cart-item-details">
                        <div class="cart-item-title">@item.Title</div>
                        <div class="cart-item-platform">@item.Platform</div>
                    </div>
                    <div class="cart-item-quantity">
                        <form asp-controller="Cart" asp-action="UpdateQuantity" method="post" class="d-flex align-items-center gap-2">
                            <input type="hidden" name="gameId" value="@item.GameId" />
                            <button type="button" class="qty-btn qty-decrease">−</button>
                            <input type="number" name="quantity" value="@item.Quantity" min="1" class="qty-input" />
                            <button type="button" class="qty-btn qty-increase">+</button>
                        </form>
                    </div>
                    <div class="cart-item-price">
                        $@((item.Price * item.Quantity).ToString("F2"))
                    </div>
                    <div class="cart-item-remove">
                        <form asp-controller="Cart" asp-action="RemoveFromCart" method="post">
                            <input type="hidden" name="gameId" value="@item.GameId" />
                            <button type="submit" class="btn-remove" title="Remove">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>

        <div class="cart-summary">
            <div class="cart-summary-card">
                <h4 class="cart-summary-title">Order Summary</h4>
                <div class="summary-row">
                    <span>Subtotal (@Model.Sum(c => c.Quantity) items)</span>
                    <span>$@total.ToString("F2")</span>
                </div>
                <div class="summary-row">
                    <span>Shipping</span>
                    <span class="text-success">Free</span>
                </div>
                <hr class="detail-divider" />
                <div class="summary-row summary-total">
                    <span>Total</span>
                    <span>$@total.ToString("F2")</span>
                </div>
                <form asp-controller="Cart" asp-action="Checkout" method="post">
                    <button type="submit" class="btn-checkout">
                        <i class="bi bi-credit-card"></i> Proceed to Checkout
                    </button>
                </form>
            </div>
        </div>
    </div>
}
