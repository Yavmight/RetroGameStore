<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Retro Nexus</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Inter:wght@400;600;700;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

@{
    var userRole = Context.Session.GetString("UserRole");
    var userName = Context.Session.GetString("UserName");
    var isLoggedIn = userRole != null;
    var profileAction = userRole == "Customer" ? "CustomerProfile" : "StaffProfile";
    var cartCount = 0;
    if (isLoggedIn)
    {
        var cartJson = Context.Session.GetString("ShoppingCart");
        if (!string.IsNullOrEmpty(cartJson))
        {
            try
            {
                var cartItems = System.Text.Json.JsonSerializer.Deserialize<List<RetroGameStore.Models.CartItem>>(cartJson);
                cartCount = cartItems?.Sum(c => c.Quantity) ?? 0;
            }
            catch { }
        }
    }
}

<!-- Navbar -->
<nav class="navbar navbar-expand-lg navbar-retro">
    <div class="container">
        <a class="navbar-brand" asp-controller="Dashboard" asp-action="Index">
            🕹️ RETRO NEXUS
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                @if (isLoggedIn && (userRole == "Admin" || userRole == "Staff"))
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Dashboard" asp-action="Index">
                            <i class="bi bi-speedometer2"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Games" asp-action="Index">
                            <i class="bi bi-joystick"></i> Inventory
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Games" asp-action="LowStock">
                            <i class="bi bi-exclamation-triangle"></i> Low Stock
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Orders" asp-action="SalesLog">
                            <i class="bi bi-receipt"></i> Sales Log
                        </a>
                    </li>
                }

                @if (isLoggedIn && userRole == "Admin")
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Customers" asp-action="Index">
                            <i class="bi bi-people"></i> Customers
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Staff" asp-action="Index">
                            <i class="bi bi-person-badge"></i> Staff
                        </a>
                    </li>
                }

                @if (isLoggedIn && userRole == "Customer")
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Orders" asp-action="Browse">
                            <i class="bi bi-shop"></i> Browse Games
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="CustomerProfile">
                            <i class="bi bi-person-circle"></i> My Profile
                        </a>
                    </li>
                }

            </ul>

            <!-- Right side: cart + user info + logout -->
            <ul class="navbar-nav ms-auto">
                @if (isLoggedIn && userRole == "Customer")
                {
                    <li class="nav-item d-flex align-items-center me-2">
                        <a class="nav-link cart-nav-link" asp-controller="Cart" asp-action="Index">
                            <i class="bi bi-cart3" style="font-size: 1.2rem;"></i>
                            @if (cartCount > 0)
                            {
                                <span class="cart-badge">@cartCount</span>
                            }
                        </a>
                    </li>
                }
                @if (isLoggedIn)
                {
                    <li class="nav-item d-flex align-items-center me-3">
                        <span class="badge badge-role
                            @(userRole == "Admin" ? "bg-danger" :
                              userRole == "Staff" ? "bg-warning text-dark" : "bg-success")">
                            @userRole
                        </span>
                        <a class="nav-link ms-2" asp-controller="Account" asp-action="@profileAction">👤 @userName</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-danger" asp-controller="Account" asp-action="Logout">
                            <i class="bi bi-box-arrow-right"></i> Logout
                        </a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>


<div class="container mt-3">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-x-circle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
</div>


<div class="main-content">
    <div class="container">
        @RenderBody()
    </div>
</div>


<footer class="py-3 mt-4">
    <div class="container text-center">
        <small>🕹️ Retro Nexus &copy; @DateTime.Now.Year — All your classics, one place.</small>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)

</body>

</html>
