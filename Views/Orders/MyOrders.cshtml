@model List<RetroGameStore.Models.Order>
@{
    ViewData["Title"] = "My Orders";
}

<div class="d-flex justify-content-between align-items-center mb-2">
    <div>
        <div class="page-title">📦 My Orders</div>
        <div class="page-subtitle">@ViewBag.UserName — @Model.Count order(s) total</div>
    </div>
    <a asp-action="Browse" class="btn btn-primary">
        <i class="bi bi-shop"></i> Browse Games
    </a>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5">
            <div style="font-size:3rem;">🛒</div>
            <h5 class="mt-3" style="color:#c0c0ff;">No orders yet!</h5>
            <p class="text-muted">Head over to the store and grab some classics.</p>
            <a asp-action="Browse" class="btn btn-primary mt-2">Browse Games</a>
        </div>
    </div>
}
else
{
    <!-- Summary strip -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-icon">🧾</div>
                <div class="stat-value">@Model.Count</div>
                <div class="stat-label">Orders</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card stat-success">
                <div class="stat-icon">💰</div>
                <div class="stat-value">$@Model.Where(o => o.Status == RetroGameStore.Models.OrderStatus.Completed).Sum(o => o.TotalPrice).ToString("F2")</div>
                <div class="stat-label">Total Spent</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card stat-info">
                <div class="stat-icon">🎮</div>
                <div class="stat-value">@Model.Sum(o => o.Quantity)</div>
                <div class="stat-label">Games Bought</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card stat-warning">
                <div class="stat-icon">↩️</div>
                <div class="stat-value">@Model.Count(o => o.Status == RetroGameStore.Models.OrderStatus.Refunded)</div>
                <div class="stat-label">Refunded</div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header"><i class="bi bi-clock-history"></i> Order History</div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Game</th>
                            <th>Platform</th>
                            <th>Qty</th>
                            <th>Total</th>
                            <th>Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td>#@order.Id</td>
                                <td><strong>@order.Game.Title</strong></td>
                                <td><span class="badge-platform">@order.Game.Platform</span></td>
                                <td>@order.Quantity</td>
                                <td>$@order.TotalPrice.ToString("F2")</td>
                                <td>@order.OrderDate.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <span class="badge @(order.Status == RetroGameStore.Models.OrderStatus.Completed ? "bg-success" : order.Status == RetroGameStore.Models.OrderStatus.Refunded ? "bg-danger" : "bg-warning text-dark")">
                                        @order.Status
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
