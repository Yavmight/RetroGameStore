@model List<RetroGameStore.Models.Order>
@{
    ViewData["Title"] = "Sales Log";
}

<div class="d-flex justify-content-between align-items-center mb-2">
    <div>
        <div class="page-title">🧾 Sales Log</div>
        <div class="page-subtitle">@Model.Count order(s) found</div>
    </div>
</div>

<!-- Filter Bar -->
<div class="filter-bar">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-12 col-md-4">
            <label class="form-label mb-1">Filter by Status</label>
            <select name="status" class="form-select">
                <option value="">All Statuses</option>
                @foreach (var s in Enum.GetValues<RetroGameStore.Models.OrderStatus>())
                {
                    <option value="@s" selected="@(ViewBag.StatusFilter == s.ToString())">@s</option>
                }
            </select>
        </div>
        <div class="col-12 col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-primary w-100">Filter</button>
            <a asp-action="SalesLog" class="btn btn-outline-secondary w-100">Reset</a>
        </div>
    </form>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">No orders found.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Customer</th>
                            <th>Game</th>
                            <th>Qty</th>
                            <th>Total</th>
                            <th>Date</th>
                            <th>Status</th>
                            @if (ViewBag.UserRole == "Admin")
                            {
                                <th>Action</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td>#@order.Id</td>
                                <td>@order.User.FullName</td>
                                <td>@order.Game.Title</td>
                                <td>@order.Quantity</td>
                                <td>$@order.TotalPrice.ToString("F2")</td>
                                <td>@order.OrderDate.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <span class="badge @(order.Status == RetroGameStore.Models.OrderStatus.Completed ? "bg-success" : order.Status == RetroGameStore.Models.OrderStatus.Refunded ? "bg-danger" : "bg-warning text-dark")">
                                        @order.Status
                                    </span>
                                </td>
                                @if (ViewBag.UserRole == "Admin")
                                {
                                    <td>
                                        <form asp-action="UpdateStatus" method="post" class="d-flex gap-1">
                                            <input type="hidden" name="id" value="@order.Id" />
                                            <select name="status" class="form-select form-select-sm" style="width:130px;">
                                                @foreach (var s in Enum.GetValues<RetroGameStore.Models.OrderStatus>())
                                                {
                                                    <option value="@s" selected="@(order.Status == s)">@s</option>
                                                }
                                            </select>
                                            <button type="submit" class="btn btn-sm btn-primary">
                                                <i class="bi bi-check"></i>
                                            </button>
                                        </form>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
