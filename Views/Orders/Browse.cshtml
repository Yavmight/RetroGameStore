@model List<RetroGameStore.Models.Game>
@{
    ViewData["Title"] = "Browse Games";
}

<div class="d-flex justify-content-between align-items-center mb-2">
    <div>
        <div class="page-title">🛒 Browse Games</div>
        <div class="page-subtitle">Welcome, @ViewBag.UserName — @Model.Count title(s) available</div>
    </div>
    <a asp-controller="Orders" asp-action="MyOrders" class="btn btn-outline-primary">
        <i class="bi bi-bag-check"></i> My Orders
    </a>
</div>

<!-- Filter Bar -->
<div class="filter-bar">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-12 col-md-6">
            <label class="form-label mb-1">Search</label>
            <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search by title..." />
        </div>
        <div class="col-12 col-md-3">
            <label class="form-label mb-1">Platform</label>
            <select name="platform" class="form-select">
                <option value="">All Platforms</option>
                @foreach (var p in Enum.GetValues<RetroGameStore.Models.Platform>())
                {
                    <option value="@p" selected="@(ViewBag.Platform == p.ToString())">@p</option>
                }
            </select>
        </div>
        <div class="col-12 col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-primary w-100">Search</button>
            <a asp-action="Browse" class="btn btn-outline-secondary w-100">Reset</a>
        </div>
    </form>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5 text-muted">No games found matching your search.</div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var game in Model)
        {
            <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                <div class="game-card">
                    <div class="game-platform">@game.Platform • @game.Genre • @game.ReleaseYear</div>
                    <div class="game-title">@game.Title</div>
                    <div class="game-price mb-3">$@game.Price.ToString("F2")</div>
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <small class="text-muted">In stock: <strong style="color:#00cc66">@game.Stock</strong></small>
                    </div>
                    <!-- Buy form -->
                    <form asp-action="Buy" method="post" class="d-flex gap-2">
                        <input type="hidden" name="gameId" value="@game.Id" />
                        <input type="number" name="quantity" value="1" min="1" max="@game.Stock"
                               class="form-control form-control-sm" style="width: 70px;" />
                        <button type="submit" class="btn btn-primary btn-sm w-100">
                            <i class="bi bi-cart-plus"></i> Buy
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
}
