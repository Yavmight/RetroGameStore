@model RetroGameStore.Models.Game
@{
    ViewData["Title"] = "Edit Game";
}

<div class="page-title">✏️ Edit Game</div>
<div class="page-subtitle">Updating: <strong style="color:#ff00ff">@Model.Title</strong></div>

<div class="card" style="max-width: 640px;">
    <div class="card-header"><i class="bi bi-joystick"></i> Game Details</div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-6">
                    <label asp-for="Platform" class="form-label"></label>
                    <select asp-for="Platform" class="form-select"
                            asp-items="Html.GetEnumSelectList<RetroGameStore.Models.Platform>()"></select>
                </div>
                <div class="col-6">
                    <label asp-for="Genre" class="form-label"></label>
                    <select asp-for="Genre" class="form-select"
                            asp-items="Html.GetEnumSelectList<RetroGameStore.Models.Genre>()"></select>
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-4">
                    <label asp-for="Price" class="form-label"></label>
                    <input asp-for="Price" class="form-control" />
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>
                <div class="col-4">
                    <label asp-for="Stock" class="form-label"></label>
                    <input asp-for="Stock" class="form-control" />
                    <span asp-validation-for="Stock" class="text-danger small"></span>
                </div>
                <div class="col-4">
                    <label asp-for="ReleaseYear" class="form-label"></label>
                    <input asp-for="ReleaseYear" class="form-control" />
                    <span asp-validation-for="ReleaseYear" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-4">
                <label asp-for="LowStockThreshold" class="form-label"></label>
                <input asp-for="LowStockThreshold" class="form-control" />
                <div class="form-text text-muted small">Alert will trigger when stock drops to or below this number.</div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Save Changes</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
