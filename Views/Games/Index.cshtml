@model List<RetroGameStore.Models.Game>
@{
    ViewData["Title"] = "Game Inventory";
}

<div class="d-flex justify-content-between align-items-center mb-2">
    <div>
        <div class="page-title">🎮 Game Inventory</div>
        <div class="page-subtitle">@Model.Count title(s) found</div>
    </div>
    @if (ViewBag.UserRole == "Admin")
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Add Game
        </a>
    }
</div>

<!-- Filter Bar -->
<div class="filter-bar">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-12 col-md-5">
            <label class="form-label mb-1">Search</label>
            <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search by title..." />
        </div>
        <div class="col-6 col-md-3">
            <label class="form-label mb-1">Platform</label>
            <select name="platform" class="form-select">
                <option value="">All Platforms</option>
                @foreach (var p in Enum.GetValues<RetroGameStore.Models.Platform>())
                {
                    <option value="@p" selected="@(ViewBag.Platform == p.ToString())">@p</option>
                }
            </select>
        </div>
        <div class="col-6 col-md-2">
            <label class="form-label mb-1">Genre</label>
            <select name="genre" class="form-select">
                <option value="">All Genres</option>
                @foreach (var g in Enum.GetValues<RetroGameStore.Models.Genre>())
                {
                    <option value="@g" selected="@(ViewBag.Genre == g.ToString())">@g</option>
                }
            </select>
        </div>
        <div class="col-12 col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-primary w-100">Filter</button>
            <a asp-action="Index" class="btn btn-outline-secondary w-100">Reset</a>
        </div>
    </form>
</div>

<!-- Table -->
<div class="card">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">No games found.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Platform</th>
                            <th>Genre</th>
                            <th>Year</th>
                            <th>Price</th>
                            <th>Stock</th>
                            @if (ViewBag.UserRole == "Admin")
                            {
                                <th>Actions</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var game in Model)
                        {
                            <tr>
                                <td><strong>@game.Title</strong></td>
                                <td><span class="badge-platform">@game.Platform</span></td>
                                <td>@game.Genre</td>
                                <td>@game.ReleaseYear</td>
                                <td>$@game.Price.ToString("F2")</td>
                                <td>
                                    @if (game.IsLowStock)
                                    {
                                        <span class="badge-lowstock"><i class="bi bi-exclamation-triangle"></i> @game.Stock</span>
                                    }
                                    else
                                    {
                                        <span class="text-success fw-bold">@game.Stock</span>
                                    }
                                </td>
                                @if (ViewBag.UserRole == "Admin")
                                {
                                    <td>
                                        <a asp-action="Edit" asp-route-id="@game.Id" class="btn btn-sm btn-warning me-1">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@game.Id" method="post" class="d-inline"
                                              onsubmit="return confirm('Delete @game.Title?')">
                                            <button type="submit" class="btn btn-sm btn-danger">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
