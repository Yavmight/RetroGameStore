@model List<RetroGameStore.Models.Order>
@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-2">
    <div>
        <div class="page-title">📊 Dashboard</div>
        <div class="page-subtitle">Welcome back, @ViewBag.UserName — here's your store overview.</div>
    </div>
    @if (ViewBag.UserRole == "Admin")
    {
        <a asp-controller="Games" asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Add Game
        </a>
    }
</div>

<!-- Stat Cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-4 col-lg-2">
        <div class="stat-card">
            <div class="stat-icon">🕹️</div>
            <div class="stat-value">@ViewBag.TotalGames</div>
            <div class="stat-label">Total Titles</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="stat-card stat-info">
            <div class="stat-icon">📦</div>
            <div class="stat-value">@ViewBag.TotalStock</div>
            <div class="stat-label">Units in Stock</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="stat-card stat-warning">
            <div class="stat-icon">⚠️</div>
            <div class="stat-value">@ViewBag.LowStockCount</div>
            <div class="stat-label">Low Stock</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="stat-card">
            <div class="stat-icon">🧾</div>
            <div class="stat-value">@ViewBag.TotalSales</div>
            <div class="stat-label">Total Sales</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="stat-card stat-success">
            <div class="stat-icon">💰</div>
            <div class="stat-value">$@ViewBag.TotalRevenue.ToString("F0")</div>
            <div class="stat-label">Revenue</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="stat-card stat-info">
            <div class="stat-icon">👥</div>
            <div class="stat-value">@ViewBag.TotalCustomers</div>
            <div class="stat-label">Customers</div>
        </div>
    </div>
</div>

<!-- Recent Orders -->
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-clock-history"></i> Recent Orders</span>
        <a asp-controller="Orders" asp-action="SalesLog" class="btn btn-sm btn-outline-primary">View All</a>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">No orders yet.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Customer</th>
                            <th>Game</th>
                            <th>Total</th>
                            <th>Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td>#@order.Id</td>
                                <td>@order.User.FullName</td>
                                <td>@order.Game.Title</td>
                                <td>$@order.TotalPrice.ToString("F2")</td>
                                <td>@order.OrderDate.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <span class="badge @(order.Status == RetroGameStore.Models.OrderStatus.Completed ? "bg-success" : order.Status == RetroGameStore.Models.OrderStatus.Refunded ? "bg-danger" : "bg-warning text-dark")">
                                        @order.Status
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
