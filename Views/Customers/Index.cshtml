@model List<RetroGameStore.Models.User>
@{
    ViewData["Title"] = "Customers";
}

<div class="d-flex justify-content-between align-items-center mb-2">
    <div>
        <div class="page-title">👥 Customers</div>
        <div class="page-subtitle">@Model.Count registered customer(s)</div>
    </div>
</div>

<!-- Filter Bar -->
<div class="filter-bar">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-12 col-md-6">
            <label class="form-label mb-1">Search</label>
            <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search by name or email..." />
        </div>
        <div class="col-12 col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-primary w-100">Search</button>
            <a asp-action="Index" class="btn btn-outline-secondary w-100">Reset</a>
        </div>
    </form>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">No customers found.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Orders</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var customer in Model)
                        {
                            <tr>
                                <td>#@customer.Id</td>
                                <td><strong>@customer.FullName</strong></td>
                                <td>@customer.Email</td>
                                <td>
                                    <span class="badge bg-primary">
                                        @(ViewBag.OrderCounts.ContainsKey(customer.Id) ? ViewBag.OrderCounts[customer.Id] : 0) orders
                                    </span>
                                </td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@customer.Id" class="btn btn-sm btn-outline-primary me-1">
                                        <i class="bi bi-eye"></i> View
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@customer.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Remove @customer.FullName?')">
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
